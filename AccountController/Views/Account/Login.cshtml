@model AccountController.Models.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center">
    <div class="col-md-4 mt-5">
        <h2 class="text-center">Đăng nhập</h2>
        <hr />

        @if (ViewBag.Message != null)
        {
            var alertClass = ViewBag.Message == "Login success" ? "alert-success" : "alert-danger";
            <div class="alert @alertClass text-center" role="alert">
                @ViewBag.Message
            </div>
        }

        <form asp-action="Login" method="post">
            <div class="form-group mb-3">
                <label asp-for="Username" class="control-label mb-1">Username</label>
                <input asp-for="Username" class="form-control" required />
            </div>
            <div class="form-group mb-3">
                <label asp-for="Password" class="control-label mb-1">Password</label>
                <input asp-for="Password" type="password" class="form-control" required />
            </div>
            <div class="form-group text-center">
                <button type="submit" class="btn btn-primary w-100">Login</button>
            </div>
        </form>
    </div>
</div>
