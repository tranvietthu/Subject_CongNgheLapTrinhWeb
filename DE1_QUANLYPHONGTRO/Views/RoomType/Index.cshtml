@model IEnumerable<DE1_QUANLYPHONGTRO.Models.RoomType_BCS240041>

@{
    ViewData["Title"] = "Danh sách Loại Phòng";
}

<h1>Danh sách Loại Phòng</h1>

<table class="table">
    <thead>
        <tr>
            <th>Tên loại phòng</th>
            <th>Mô tả</th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>
