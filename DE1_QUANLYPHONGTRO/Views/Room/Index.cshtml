@model IEnumerable<DE1_QUANLYPHONGTRO.Models.Room_BCS240041>

@{
    ViewData["Title"] = "Danh sách Phòng";
}

<h1>Danh sách Phòng</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Thêm Phòng Mới</a>
</p>

<form asp-action="Index" method="get" class="mb-4">
    <div class="row align-items-end">
        <div class="col-md-3 mb-3">
            <label>Tên phòng:</label>
            <input type="text" name="searchName" value="@ViewBag.SearchName" class="form-control" placeholder="Nhập tên phòng..." />
        </div>
        <div class="col-md-3 mb-3">
            <label>Loại phòng:</label>
            <select name="roomTypeId" class="form-control" asp-items="ViewBag.RoomTypes">
                <option value="">-- Tất cả --</option>
            </select>
        </div>
        <div class="col-md-2 mb-3">
            <label>Trạng thái:</label>
            <select name="isAvailable" class="form-control">
                <option value="">-- Tất cả --</option>
                <option value="true" selected="@(ViewBag.IsAvailable == true)">Còn phòng</option>
                <option value="false" selected="@(ViewBag.IsAvailable == false)">Đã thuê</option>
            </select>
        </div>
        <div class="col-md-2 mb-3">
            <label>Giá tối đa:</label>
            <input type="number" step="0.01" name="maxPrice" value="@ViewBag.MaxPrice" class="form-control" placeholder="Max price..." />
        </div>
        
        <div class="col-md-2 mb-3">
            <label>Sắp xếp:</label>
            <select name="sortOrder" class="form-control">
                <option value="">-- Mặc định --</option>
                <option value="price_asc" selected="@(ViewBag.SortOrder == "price_asc")">Giá tăng dần</option>
                <option value="price_desc" selected="@(ViewBag.SortOrder == "price_desc")">Giá giảm dần</option>
                <option value="area_desc" selected="@(ViewBag.SortOrder == "area_desc")">Diện tích giảm dần</option>
            </select>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <button type="submit" class="btn btn-secondary">Tìm kiếm / Lọc / Sắp xếp</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Xóa bộ lọc</a>
        </div>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-warning">Tìm kiếm không có kết quả.</div>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Tên phòng</th>
                <th>Loại phòng</th>
                <th>Giá (VND)</th>
                <th>Diện tích (m²)</th>
                <th>Giá / 1m² (VND)</th>
                <th>Trạng thái</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.RoomType?.Name</td>
                    <td>@item.Price.ToString("N0")</td>
                    <td>@item.Area</td>
                    <td>
                        @{
                            var pricePerSqm = item.Area > 0 ? item.Price / (decimal)item.Area : 0;
                        }
                        @pricePerSqm.ToString("N0")
                    </td>
                    <td>@(item.IsAvailable ? "Còn phòng" : "Đã thuê")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id">Sửa</a> |
                        <a asp-action="Details" asp-route-id="@item.Id">Chi tiết & Ảnh</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
